{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pwd && ls -a && cd ../../ && bun install",
  "buildCommand": "cd ../../ && bunx nx build slack-oauth-backend --prod",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
